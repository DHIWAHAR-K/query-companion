# Application
DEBUG=false
VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/queryus
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379
SCHEMA_CACHE_TTL=3600

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=your-fernet-encryption-key-change-this

# LLM Configuration
# Choose provider: "anthropic" or "google"
LLM_PROVIDER=google

# Anthropic (Claude) - Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
VALTRYEK_MODEL=claude-haiku-3-5-20241022
ACHILLIES_MODEL=claude-sonnet-4-20250514
SPRYZEN_MODEL=claude-opus-4-5-20251101

# Google (Gemini) - Only needed if LLM_PROVIDER=google
GOOGLE_API_KEY=AIzaSyBe69gnydcPsiTuAD-FNHXw3yVrimsrV34
# Use stable model IDs: https://ai.google.dev/gemini-api/docs/models/gemini
GOOGLE_VALTRYEK_MODEL=gemini-2.5-flash-lite
GOOGLE_ACHILLIES_MODEL=gemini-2.5-flash
GOOGLE_SPRYZEN_MODEL=gemini-2.5-pro

# Tools
ENABLE_WEB_SEARCH=true
TAVILY_API_KEY=tvly-your-api-key-here
ENABLE_VISION=true

# Query Execution
MAX_CONCURRENT_QUERIES=10
DEFAULT_QUERY_TIMEOUT=300
MAX_RESULT_ROWS=10000
